{
  "name": "my-first-server",
  "version": "1.1.0",
  "description": "Simple student list app with Express and Postgres",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:dev": "nodemon server.js",
    "migrate": "psql $DATABASE_URL -f migrations/create_students.sql",
    "seed": "psql $DATABASE_URL -f migrations/seed_students.sql"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
